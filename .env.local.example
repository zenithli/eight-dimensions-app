# .env.local
# このファイルをコピーして .env.local を作成
# cp .env.local.example .env.local

# ── Anthropic API Key（必須）──
ANTHROPIC_API_KEY="sk-ant-..."

# ── PostgreSQL（任意・設定しなくても動作します）──
# Supabase 無料枠 推奨:
#   https://supabase.com → New Project → Settings > Database > URI
#   DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ID].supabase.co:5432/postgres"
#
# Neon 無料枠:
#   https://neon.tech → Connection string
#   DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require"
#
# DB設定後の初期化:
#   npx prisma generate   （型生成）
#   npx prisma db push    （テーブル作成）
# DATABASE_URL="postgresql://..."
